rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Leads collection (Existing setup)
    match /leads/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // 2. Compliance Audits Collection (New setup)
    match /audits/{auditId} {
      // Anyone can submit an audit (public write via API/client)
      allow create: if true;
      
      // Only authenticated users (Admin panel) can read or modify exist audits
      allow read, update, delete: if request.auth != null;
    }
  }
}
